{
  "$schema": "https://specflow.org/specflow-config.json",
  "language": {
    "feature": "en-US"
  },
  "bindingCulture": {
    "name": "en-US"
  },
  "framework": {
    "name": "NUnit"
  },
  "stepAssemblies": [
    {
      "assembly": "LDSAPITest"
    }
  ],
  "trace": {
    "traceSuccessfulSteps": true,
    "traceTimings": true,
    "minTracedDuration": "0:0:0.1",
    "stepDefinitionSkeletonStyle": "RegexAttribute"
  }
}