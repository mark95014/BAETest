<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- Configurations that affect the Test Framework -->
  <RunConfiguration>
    <ResultsDirectory>.\TestResults</ResultsDirectory>
    <EnvironmentVariables>
    </EnvironmentVariables>
  </RunConfiguration>
  
  <!-- SpecFlow Configuration -->
  <SpecFlow>
    <Trace>
      <StepDefinitionSkeletonStyle>RegexAttribute</StepDefinitionSkeletonStyle>
    </Trace>
  </SpecFlow>
	
  <!-- Parameters used by tests at runtime -->
  <TestRunParameters>

    <!-- Common test parameters -->
    <Parameter name="verbose" value="false"/>
    <Parameter name="enableTestRail" value="false"/>
    <Parameter name="environment" value="local"/> <!--qa,dev,stg,uat,prod,local-->
    <Parameter name="testRailRunId" value="285348"/>
    <Parameter name="milestoneId" value="2533"/>
    <Parameter name="projectId" value="51"/>
	<Parameter name="generateExpectedResults" value="false"/>
	<Parameter name="expectedResultsFolder" value="../../../data/expectedResults" />
    
    <!-- Database parameters (shared with UI tests if needed) -->
    <Parameter name="databaseUserName" value="QAUser"/>
    <Parameter name="databasePassword" value="QAPassword"/>
    <Parameter name="databaseRootName" value="QADatabase"/>
    
    <!-- Database servers -->
    <Parameter name="local.databaseServer" value="." />
    <Parameter name="qa.databaseServer" value="qadb.bae.com" />
    <Parameter name="uat.databaseServer" value="uatdb.bae.com" />
    <Parameter name="stg.databaseServer" value="stgdb.bae.com" />
    <Parameter name="prod.databaseServer" value="db.bae.com" />
    
    <!-- API Test specific parameters -->
    <!-- TODO: Update these URLs to match your actual API endpoints -->
    <Parameter name="apiBaseURL" value="https://api-{environment}.bae.com/api/" />
    
    <Parameter name="local.apiBaseURL" value="https://localhost:7031/api/HotelBooking/" />
    <Parameter name="qa.apiBaseURL" value="https://api-qa.bae.com/api/" />
    <Parameter name="dev.apiBaseURL" value="https://api-dev.bae.com/api/" />
    <Parameter name="uat.apiBaseURL" value="https://api-uat.bae.com/api/" />
    <Parameter name="stg.apiBaseURL" value="https://api-stg.bae.com/api/" />
    <Parameter name="prod.apiBaseURL" value="https://api-prod.bae.com/api/" />
    
    <!-- API Configuration -->
    <Parameter name="apiTimeout" value="30"/> <!-- API request timeout in seconds -->
    <Parameter name="apiRetryCount" value="3"/> <!-- Number of retries for failed requests -->
    <Parameter name="apiRetryDelayMs" value="1000"/> <!-- Delay between retries in milliseconds -->
    
    <!-- API Authentication -->
    <Parameter name="apiUsername" value="BAEQAAutomation"/>
    <Parameter name="apiPassword" value="ToBeDetermined"/>
    <Parameter name="apiAuthType" value="None"/> <!-- Basic, Bearer, ApiKey, or None -->
    <Parameter name="apiBearerToken" value=""/> <!-- If using Bearer token authentication -->
    <Parameter name="apiKeyHeaderName" value="X-API-Key"/> <!-- If using API key authentication -->
    <Parameter name="apiKeyValue" value=""/> <!-- If using API key authentication -->

	<!-- Connection string for local SQL Server database -->
    <Parameter name="ConnectionString" value="Server=MARK-HP-LAPTOP;Database=BookingDb;Integrated Security=true;TrustServerCertificate=True;" />
	<Parameter name="SqlScriptsPath" value="C:\Users\mark9\source\repos\HotelBooking\database" />
	  
</TestRunParameters>

</RunSettings>