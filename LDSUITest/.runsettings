<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>.\TestResults</ResultsDirectory>
    <TargetPlatform>x64</TargetPlatform>
  </RunConfiguration>
  
  <NUnit>
    <NumberOfTestWorkers>4</NumberOfTestWorkers>
    <DefaultTimeout>120000</DefaultTimeout>
    <InternalTraceLevel>Off</InternalTraceLevel>
  </NUnit>
  
  <TestRunParameters>
    <Parameter name="verbose" value="false" />
    <Parameter name="generateExpectedResults" value="true" />
    <Parameter name="expectedResultsFolder" value="../../../data/expectedResults" />
    <Parameter name="enableTestRail" value="false" />
    <Parameter name="testRailRunId" value="" />
    <Parameter name="projectId" value="1" />
    <Parameter name="milestoneId" value="1" />
    <Parameter name="environment" value="dev" />
    
    <!-- Selenium Configuration -->
    <Parameter name="browser" value="chrome" />
    <Parameter name="headless" value="true" />
    
    <!-- Web base URL for dev environment -->
    <Parameter name="dev.webBaseURL" value="https://localhost:7031" />
  </TestRunParameters>
</RunSettings>